# TextffCut 環境変数設定例
# このファイルをコピーして .env ファイルを作成し、必要な設定を入力してください

# =============================================================================
# Whisper API設定
# =============================================================================

# APIモードを使用するか（true/false）
TEXTFFCUT_USE_API=false

# OpenAI APIキー
TEXTFFCUT_API_KEY=sk-your_openai_api_key_here

# =============================================================================
# Whisperモデル設定
# =============================================================================

# Whisperモデルサイズ（ローカル版の場合）
TEXTFFCUT_MODEL_SIZE=large-v3

# 出力ディレクトリ
TEXTFFCUT_OUTPUT_DIR=output

# =============================================================================
# Streamlit Cloud設定例
# =============================================================================

# Streamlit Cloudにデプロイする場合は、以下の設定を secrets.toml に記述してください：
# [secrets]
# TEXTFFCUT_USE_API = "true"
# TEXTFFCUT_API_KEY = "sk-xxx..."

# =============================================================================
# API料金目安（2024年5月時点）
# =============================================================================

# OpenAI Whisper API: $0.006/分
# 30分の動画 = 約$0.18（約27円）
# 90分の動画 = 約$0.54（約81円）

# ※料金は変動する可能性があります。最新の料金は各サービスの公式サイトでご確認ください。