#!/usr/bin/env python3
"""textffcut ランチャー — ソースからの直接実行用。

pip install せずにソースディレクトリから使う場合:
  1. このファイルにPATHを通す:
     export PATH="/path/to/TextffCut/bin:$PATH"
  2. どのディレクトリからでも実行可能:
     textffcut gui
     textffcut clip ./動画.mp4
"""

import sys
from pathlib import Path

# プロジェクトルートを sys.path に追加
project_root = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(project_root))

from textffcut_cli.command import main

main()
